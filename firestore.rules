rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Site content (settings, programs, achievements, gallery, notices)
    // Anyone can READ (so the public site displays correctly).
    // Only a signed-in admin can WRITE (add/edit/delete).
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Visitor contact-form messages
    // Anyone can CREATE a message (submit the contact form).
    // Only a signed-in admin can READ, UPDATE, or DELETE messages
    // (keeps visitor messages private from other visitors).
    match /messages/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
